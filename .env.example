# Environment variables for WAN Video Generator
# Copy this file to .env and fill in your actual values

# Application settings
APP_ENV=development
DEBUG=true

# Alibaba Cloud DashScope API Key
# Get your API key from: https://www.alibabacloud.com/help/en/model-studio/getting-started/get-api-key
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Cloudflare R2 Storage Configuration
# Required for image uploads to the WAN API
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT_URL=
R2_BUCKET_NAME=
R2_PUBLIC_URL_BASE=
